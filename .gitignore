# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Bind-mounted from addnewfeature (source of truth)
lib/feedback-lib/
app/api/feedback/
app/feedback-lib-issues/

# Android project (bind-mounted from addnewfeature)
mobile/feedback-lib/
mobile/build-logic/

# Android build artifacts / local config
mobile/local.properties
mobile/.gradle/
mobile/.kotlin/
mobile/build/
mobile/app/build/
mobile/**/build/
mobile/shared/build/
mobile/captures/
*.apk
*.aab
*.keystore
*.jks

# Seed / business data with PII — never commit (lives in the DB only)
seed/*.local.*
data/customers*.json

# Uploaded delivery photos/videos
/public/uploads/
