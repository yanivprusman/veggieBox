<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext HTTP is allowed only for the WireGuard overlay peers (10.7.0.0/24) and
  the home-LAN hosts (NUC .142 / desktop .143). The backend's real, distributable
  endpoint is HTTPS (no cleartext entry needed). Source of truth for peer IPs:
  terminal/firstThing.sh. Do NOT reintroduce 10.0.0.{1..6} — those are dead.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.7.0.1</domain>
        <domain includeSubdomains="false">10.7.0.2</domain>
        <domain includeSubdomains="false">10.7.0.3</domain>
        <domain includeSubdomains="false">10.7.0.4</domain>
        <domain includeSubdomains="false">10.7.0.6</domain>
        <domain includeSubdomains="false">10.0.0.142</domain>
        <domain includeSubdomains="false">10.0.0.143</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
